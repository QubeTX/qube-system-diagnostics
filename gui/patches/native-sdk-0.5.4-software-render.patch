+    if (detail) {
+        gtk_message_dialog_format_secondary_text(GTK_MESSAGE_DIALOG(dialog), "%s", detail);
+    }
+    gtk_dialog_add_button(dialog, primary ? primary : "OK", 0);
+    if (secondary) gtk_dialog_add_button(dialog, secondary, 1);
+    if (tertiary) gtk_dialog_add_button(dialog, tertiary, 2);
+    native_sdk_alert_state_t state = { .loop = g_main_loop_new(NULL, FALSE), .response = 0 };
