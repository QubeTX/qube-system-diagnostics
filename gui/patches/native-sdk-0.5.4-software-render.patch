+/* GtkFileDialog was introduced in GTK 4.10. Keep the Native SDK dialog
+ * contract available on the Ubuntu 22.04 compatibility floor through the
+ * GTK 4.0 GtkFileChooserNative API. The public result encoding remains
+ * identical; only the platform presentation primitive changes. */
+static void native_sdk_legacy_open_dialog_done(GtkNativeDialog *source, gint response, gpointer data) {
+    native_sdk_file_dialog_state_t *state = data;
+    if (response == GTK_RESPONSE_ACCEPT) {
+        state->files = gtk_file_chooser_get_files(GTK_FILE_CHOOSER(source));
+    }
+    g_main_loop_quit(state->loop);
+}
+
+static void native_sdk_legacy_save_dialog_done(GtkNativeDialog *source, gint response, gpointer data) {
+    native_sdk_file_dialog_state_t *state = data;
+    if (response == GTK_RESPONSE_ACCEPT) {
+        state->file = gtk_file_chooser_get_file(GTK_FILE_CHOOSER(source));
+    }
+    g_main_loop_quit(state->loop);
+}
