+test "glyph coverage masks reuse raster across position color and background" {
+    const width: usize = 128;
+    const height: usize = 72;
+    const bounds = geometry.RectF.init(0, 0, width, height);
+    const first = RenderCommand{
+        .command = .{ .draw_text = .{
+            .id = 1,
+            .font_id = default_mono_font_id,
+            .size = 28,
+            .origin = geometry.PointF.init(18, 44),
+            .color = Color.rgb8(232, 232, 232),
+            .text = "8",
+        } },
+        .local_bounds = bounds,
+        .bounds = bounds,
+    };
+    const moved = RenderCommand{
+        .command = .{ .draw_text = .{
+            .id = 1,
+            .font_id = default_mono_font_id,
+            .size = 28,
+            .origin = geometry.PointF.init(74, 52),
+            .color = Color.rgb8(255, 94, 26),
+            .text = "8",
+        } },
+        .local_bounds = bounds,
+        .bounds = bounds,
+    };
+    const changed_background = Color.rgb8(27, 22, 19);
+
+    var memo = canvas.ReferenceRenderMemo.init(std.testing.allocator);
+    defer memo.deinit();
+    var cached_pixels: [width * height * 4]u8 = undefined;
+    const cached = (try ReferenceRenderSurface.init(width, height, &cached_pixels)).withRenderMemo(&memo);
+    try blendSplitRenderPass(cached, first, Color.rgb8(9, 9, 9), width, height);
+    try std.testing.expectEqual(@as(u64, 1), memo.glyph_mask_misses);
+    try std.testing.expectEqual(@as(u64, 0), memo.glyph_mask_hits);
+
+    // Integer translation, foreground color, and all destination pixels
+    // change. Coverage remains identical, so the second frame must hit the
+    // mask and still match a direct reference render byte-for-byte.
+    try blendSplitRenderPass(cached, moved, changed_background, width, height);
+    try std.testing.expectEqual(@as(u64, 1), memo.glyph_mask_misses);
+    try std.testing.expectEqual(@as(u64, 1), memo.glyph_mask_hits);
+
+    var direct_pixels: [width * height * 4]u8 = undefined;
+    const direct = try ReferenceRenderSurface.init(width, height, &direct_pixels);
+    try blendSplitRenderPass(direct, moved, changed_background, width, height);
+    try std.testing.expectEqualSlices(u8, direct_pixels[0..], cached_pixels[0..]);
+
+    // A different fractional phase is a distinct raster key. It may not
+    // borrow coverage computed on another pixel phase.
+    var fractional = moved;
+    fractional.command.draw_text.origin.x += 0.25;
+    try blendSplitRenderPass(cached, fractional, changed_background, width, height);
+    try std.testing.expectEqual(@as(u64, 2), memo.glyph_mask_misses);
+    try blendSplitRenderPass(direct, fractional, changed_background, width, height);
+    try std.testing.expectEqualSlices(u8, direct_pixels[0..], cached_pixels[0..]);
+}
