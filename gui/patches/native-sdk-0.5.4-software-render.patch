 }
+#else
+static void native_sdk_legacy_alert_done(GtkDialog *source, gint response, gpointer data) {
+    (void)source;
+    native_sdk_alert_state_t *state = data;
+    state->response = response;
+    g_main_loop_quit(state->loop);
+}
