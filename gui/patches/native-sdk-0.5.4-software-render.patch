+            entry.pixels = self.allocator.alloc(u8, byte_len) catch return null;
+        }
+        entry.key = key;
+        entry.used = true;
+        return entry.pixels;
+    }
+
+    fn glyphSlot(key: Key) usize {
+        var hasher = std.hash.Wyhash.init(0xa63d_2b91);
+        hasher.update(std.mem.asBytes(&key.surface_width));
+        hasher.update(std.mem.asBytes(&key.surface_height));
+        hasher.update(std.mem.asBytes(&key.rect_x));
+        hasher.update(std.mem.asBytes(&key.rect_y));
+        hasher.update(std.mem.asBytes(&key.rect_width));
+        hasher.update(std.mem.asBytes(&key.rect_height));
+        hasher.update(std.mem.asBytes(&key.params_hash));
+        hasher.update(std.mem.asBytes(&key.source_hash));
+        return @intCast(hasher.final() % max_glyph_entries);
+    }
+
+    /// Find a reusable coverage mask. A hit refreshes its stamp so the
+    /// bounded pool keeps the glyphs a live dashboard is actively using.
+    pub fn findGlyphMask(self: *ReferenceRenderMemo, key: GlyphMaskKey) ?GlyphMask {
+        const entry = &self.glyph_mask_entries[glyphMaskSlot(key)];
+        if (!entry.used or !std.meta.eql(entry.key, key)) {
+            self.glyph_mask_misses += 1;
+            return null;
+        }
+        self.clock += 1;
+        entry.stamp = self.clock;
+        self.glyph_mask_hits += 1;
+        return entry.view();
+    }
+
+    /// Reserve zeroed f32 coverage for one glyph. The entry remains hidden
+    /// until `commitGlyphMask` so a recoverable raster failure can never
+    /// publish a partial mask. The caller writes exactly one coverage value
+    /// for every emitted pixel; untouched cells stay transparent.
+    pub fn prepareGlyphMask(
+        self: *ReferenceRenderMemo,
+        key: GlyphMaskKey,
+        offset_x: i32,
+        offset_y: i32,
+        width: usize,
+        height: usize,
+    ) ?[]f32 {
+        const pixel_len = std.math.mul(usize, width, height) catch return null;
+        const byte_len = std.math.mul(usize, pixel_len, @sizeOf(f32)) catch return null;
+        if (pixel_len == 0 or byte_len > max_glyph_mask_entry_bytes) return null;
+
+        const entry = &self.glyph_mask_entries[glyphMaskSlot(key)];
+        self.evictGlyphMask(entry);
+        while (self.glyph_mask_total_bytes + byte_len > max_glyph_mask_total_bytes) {
+            const oldest = self.oldestGlyphMaskEntry() orelse return null;
+            self.evictGlyphMask(oldest);
+        }
+        entry.coverage = self.allocator.alloc(f32, pixel_len) catch {
+            entry.* = .{};
+            return null;
+        };
+        @memset(entry.coverage, 0);
+        self.glyph_mask_total_bytes += byte_len;
+        entry.key = key;
+        entry.offset_x = offset_x;
+        entry.offset_y = offset_y;
+        entry.width = width;
+        entry.height = height;
+        entry.used = false;
+        return entry.coverage;
+    }
+
+    pub fn commitGlyphMask(self: *ReferenceRenderMemo, key: GlyphMaskKey) void {
+        const entry = &self.glyph_mask_entries[glyphMaskSlot(key)];
+        if (entry.coverage.len == 0 or !std.meta.eql(entry.key, key)) return;
+        self.clock += 1;
+        entry.stamp = self.clock;
+        entry.used = true;
+    }
+
+    fn oldestGlyphMaskEntry(self: *ReferenceRenderMemo) ?*GlyphMaskEntry {
+        var oldest: ?*GlyphMaskEntry = null;
+        for (&self.glyph_mask_entries) |*entry| {
+            if (entry.coverage.len == 0) continue;
+            if (oldest == null or entry.stamp < oldest.?.stamp) oldest = entry;
+        }
+        return oldest;
+    }
+
+    fn evictGlyphMask(self: *ReferenceRenderMemo, entry: *GlyphMaskEntry) void {
+        if (entry.coverage.len > 0) {
+            self.glyph_mask_total_bytes -= entry.coverage.len * @sizeOf(f32);
+            self.allocator.free(entry.coverage);
+        }
+        entry.* = .{};
+    }
+
+    fn glyphMaskSlot(key: GlyphMaskKey) usize {
+        var hasher = std.hash.Wyhash.init(0x2c67_d495);
+        hasher.update(std.mem.asBytes(&key.face_identity));
+        hasher.update(std.mem.asBytes(&key.glyph));
+        hasher.update(std.mem.asBytes(&key.transform_a));
+        hasher.update(std.mem.asBytes(&key.transform_b));
+        hasher.update(std.mem.asBytes(&key.transform_c));
+        hasher.update(std.mem.asBytes(&key.transform_d));
+        hasher.update(std.mem.asBytes(&key.phase_x));
+        hasher.update(std.mem.asBytes(&key.phase_y));
+        return @intCast(hasher.final() % max_glyph_mask_entries);
+    }
