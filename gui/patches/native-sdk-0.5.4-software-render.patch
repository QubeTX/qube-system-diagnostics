+                if (needed <= buffer_len - offset) {
+                    if (result.count > 0) buffer[offset++] = '\n';
+                    memcpy(buffer + offset, path, len);
+                    offset += len;
+                    result.count++;
+                } else {
+                    overflow = 1;
