+test "static chrome prefix damage rendering stays byte equal and invalidates exactly" {
+    const width = 24;
+    const height = 16;
+    const surface_bounds = geometry.RectF.init(0, 0, width, height);
+    const panel_bounds = geometry.RectF.init(2, 2, 20, 12);
+    const indicator_bounds = geometry.RectF.init(7, 6, 10, 4);
+    const clear = Color.rgb8(1, 2, 3);
+
+    const Harness = struct {
+        fn commands(background: Color, indicator: Color) [4]RenderCommand {
+            return .{
+                .{
+                    .command = .{ .fill_rect = .{
+                        .id = 1,
+                        .rect = surface_bounds,
+                        .fill = .{ .color = background },
+                    } },
+                    .local_bounds = surface_bounds,
+                    .bounds = surface_bounds,
+                },
+                .{
+                    .command = .{ .shadow = .{
+                        .id = 2,
+                        .rect = panel_bounds,
+                        .radius = Radius.all(2),
+                        .offset = .{ .dx = 0, .dy = 1 },
+                        .blur = 2,
+                        .spread = 0,
+                        .color = Color.rgba8(0, 0, 0, 160),
+                    } },
+                    .local_bounds = surface_bounds,
+                    .bounds = surface_bounds,
+                },
+                .{
+                    .command = .{ .fill_rounded_rect = .{
+                        .id = 3,
+                        .rect = panel_bounds,
+                        .radius = Radius.all(2),
+                        .fill = .{ .color = Color.rgb8(18, 18, 18) },
+                    } },
+                    .local_bounds = panel_bounds,
+                    .bounds = panel_bounds,
+                },
+                .{
+                    .command = .{ .fill_rounded_rect = .{
+                        .id = 4,
+                        .rect = indicator_bounds,
+                        .radius = Radius.all(1.5),
+                        .fill = .{ .color = indicator },
+                    } },
+                    .local_bounds = indicator_bounds,
+                    .bounds = indicator_bounds,
+                },
+            };
+        }
+
+        fn fullPass(render_commands: []const RenderCommand) CanvasRenderPass {
+            return .{
+                .surface_size = geometry.SizeF.init(width, height),
+                .full_repaint = true,
+                .commands = render_commands,
+            };
+        }
+
+        fn damagePass(render_commands: []const RenderCommand) CanvasRenderPass {
+            return .{
+                .surface_size = geometry.SizeF.init(width, height),
+                .dirty_bounds = indicator_bounds,
+                .commands = render_commands,
+            };
+        }
+    };
+
+    var direct_pixels: [width * height * 4]u8 = undefined;
+    var retained_pixels: [width * height * 4]u8 = undefined;
+    const direct = try ReferenceRenderSurface.init(width, height, &direct_pixels);
+    var memo = canvas.ReferenceRenderMemo.init(std.testing.allocator);
+    defer memo.deinit();
+    memo.min_pixels = 0;
+    const retained = (try ReferenceRenderSurface.init(width, height, &retained_pixels)).withRenderMemo(&memo);
+
+    const initial = Harness.commands(Color.rgb8(9, 9, 9), Color.rgb8(255, 94, 26));
+    const initial_pass = Harness.fullPass(&initial);
+    try direct.renderPass(initial_pass, clear);
+    try std.testing.expectEqual(.damage, try retained.renderPassDamageWithStaticPrefix(initial_pass, clear, &.{}, 1));
+    try std.testing.expectEqualSlices(u8, &direct_pixels, &retained_pixels);
+
+    // The cache hit restores only the dirty indicator region, then the
+    // shadow/fill suffix replays. Occluded shadow pixels and opaque fill fast
+    // paths must remain byte-for-byte identical to the ordinary renderer.
+    const changed = Harness.commands(Color.rgb8(9, 9, 9), Color.rgb8(255, 180, 32));
+    direct.clear(clear);
+    try direct.renderPass(Harness.fullPass(&changed), clear);
+    const changed_pass = Harness.damagePass(&changed);
+    try std.testing.expectEqual(.fallback, try retained.renderPassDamageWithStaticPrefix(changed_pass, clear, &.{indicator_bounds}, 1));
+    try std.testing.expectEqualSlices(u8, &direct_pixels, &retained_pixels);
+
+    // Any prefix byte change produces a new fingerprint and a complete cache
+    // replacement; dimensions/scale/clear color participate in the same key.
+    const rebranded = Harness.commands(Color.rgb8(12, 8, 4), Color.rgb8(255, 180, 32));
+    direct.clear(clear);
+    try direct.renderPass(Harness.fullPass(&rebranded), clear);
+    const rebranded_pass = Harness.fullPass(&rebranded);
+    try std.testing.expectEqual(.damage, try retained.renderPassDamageWithStaticPrefix(rebranded_pass, clear, &.{}, 1));
+    try std.testing.expectEqualSlices(u8, &direct_pixels, &retained_pixels);
+}
