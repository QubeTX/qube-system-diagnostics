+/// Result of the retained-pixel damage path. Callers do not need this to
+/// present the frame, but tests and profilers can distinguish a true sparse
+/// repaint from the deliberately conservative union fallback.
+pub const ReferenceDamageRenderMode = enum {
+    damage,
+    fallback,
+};
+
+const ReferenceDamageRegions = struct {
+    rects: [frame_model.max_canvas_frame_dirty_rects]geometry.RectF = undefined,
+    count: usize = 0,
+    bounds: ?geometry.RectF = null,
+    area: f32 = 0,
+
+    /// Add one already-clipped, outward-pixel-snapped rect. Re-scan from the
+    /// beginning after every merge: joining A can expand into B even when the
+    /// original candidate did not intersect B. That transitive closure is
+    /// what prevents a translucent command from blending an overlap twice.
+    fn add(self: *ReferenceDamageRegions, rect: geometry.RectF) bool {
+        var merged = rect;
+        var index: usize = 0;
+        while (index < self.count) {
+            if (!self.rects[index].intersects(merged)) {
+                index += 1;
+                continue;
+            }
+            merged = geometry.RectF.unionWith(self.rects[index], merged);
+            var shift = index;
+            while (shift + 1 < self.count) : (shift += 1) self.rects[shift] = self.rects[shift + 1];
+            self.count -= 1;
+            index = 0;
+        }
+        if (self.count >= self.rects.len) return false;
+        self.rects[self.count] = merged;
+        self.count += 1;
+        return true;
+    }
+
+    fn finish(self: *ReferenceDamageRegions) void {
+        self.bounds = null;
+        self.area = 0;
+        for (self.rects[0..self.count]) |rect| {
+            self.bounds = if (self.bounds) |bounds| geometry.RectF.unionWith(bounds, rect) else rect;
+            self.area += rect.width * rect.height;
+        }
+        std.sort.pdq(geometry.RectF, self.rects[0..self.count], {}, referenceDamageRectLessThan);
+    }
+};

