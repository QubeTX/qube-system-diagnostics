<!--
  The "cargo wix" subcommand provides a variety of predefined variables available
  for customization of this template. The values for each variable are set at
  installer creation time. The following variables are available:

  TargetTriple      = The rustc target triple name.
  TargetEnv         = The rustc target environment. This is typically either
                      "msvc" or "gnu" depending on the toolchain downloaded and
                      installed.
  TargetVendor      = The rustc target vendor. This is typically "pc", but Rust
                      does support other vendors, like "uwp".
  CargoTargetBinDir = The complete path to the directory containing the
                      binaries (exes) to include. The default would be
                      "target\release\". If an explicit rustc target triple is
                      used, i.e. cross-compiling, then the default path would
                      be "target\<CARGO_TARGET>\<CARGO_PROFILE>",
                      where "<CARGO_TARGET>" is replaced with the "CargoTarget"
                      variable value and "<CARGO_PROFILE>" is replaced with the
                      value from the "CargoProfile" variable. This can also
                      be overridden manually with the "target-bin-dir" flag.
  CargoTargetDir    = The path to the directory for the build artifacts, i.e.
                      "target".
  CargoProfile      = The cargo profile used to build the binaries
                      (usually "debug" or "release").
  Version           = The version for the installer. The default is the
                      "Major.Minor.Fix" semantic versioning number of the Rust
                      package.
-->

<!--
  Please do not remove these pre-processor If-Else blocks. These are used with
  the `cargo wix` subcommand to automatically determine the installation
  destination for 32-bit versus 64-bit installers. Removal of these lines will
  cause installation errors.
-->
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='SD-300 Global'
        UpgradeCode='A7C3E1D4-9F8B-4E2A-B6D1-3F5C8A0E7B94'
        Manufacturer='Emmett S'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='SD-300 terminal diagnostics and native system monitor (Global Edition)'
            Manufacturer='Emmett S'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            AllowDowngrades='yes'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='sd300 Installation'/>
        <Property Id='SD300PRESERVEGUISTATE' Secure='yes'/>
        <Property Id='SD300GUIALREADYSTOPPED' Secure='yes'/>
        <Property Id='SD300CARGOHOME' Secure='yes'/>
        <!-- Qualification-only fault injection. This is secure so a quiet
             elevated install receives the explicit command-line property. -->
        <Property Id='SD300TESTFAILAFTERCARGO' Secure='yes'/>
        <Property Id='SD300OWNEDNATIVEROOT'>
            <RegistrySearch Id='FindOwnedGlobalNativeRoot'
                Root='HKLM'
                Key='Software\SD300'
                Name='NativeInstallRootGlobal'
                Type='directory'
                Win64='yes'/>
        </Property>
        <Property Id='CONFLICTING_INNO_UNINSTALL'>
            <RegistrySearch Id='FindConflictingGlobalInno'
                Root='HKLM'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{DC74D35F-CBF4-425F-B11E-E9EA87C13CA9}_is1'
                Name='UninstallString'
                Type='raw'
                Win64='yes'/>
        </Property>
        <Property Id='OTHEREDITIONINNO'>
            <RegistrySearch Id='FindCorporateInnoForSafeStop'
                Root='HKCU'
                Key='Software\Microsoft\Windows\CurrentVersion\Uninstall\{ED209931-B5C0-43AE-89F6-83EE2C581653}_is1'
                Name='UninstallString'
                Type='raw'
                Win64='yes'/>
        </Property>
        <Upgrade Id='143F59B2-5D4B-4F6F-B258-BB44F9C50CC9'>
            <UpgradeVersion Minimum='0.0.0'
                IncludeMinimum='yes'
                OnlyDetect='yes'
                Property='OTHEREDITIONMSI'/>
        </Upgrade>
        <Condition Message='Corporate Edition is installed. Setup stopped before changing anything. Uninstall it first or use the managed installer: https://github.com/QubeTX/qube-system-diagnostics/releases/latest'>
            <![CDATA[NOT OTHEREDITIONMSI AND NOT OTHEREDITIONINNO]]>
        </Condition>
        <Condition Message='SD-300 setup requires Windows Installer rollback support so an existing Cargo installation can be restored if setup fails.'>
            <![CDATA[Installed OR NOT RollbackDisabled]]>
        </Condition>

        <!-- MIC-1 strict cross-method convergence (v4.2.0+). A fresh native
             package is authoritative, so both interactive and passive installs
             must retire an exact shadowing managed/Cargo copy and any orphaned
             opposite-edition executable. Registered opposite-scope products are
             rejected by the LaunchCondition above before mutation. The bounded
             deletion logic lives in `sd300 migrate-cleanup`; the deferred,
             impersonated, Return=check actions below make incomplete or ambiguous
             convergence fail the MSI transaction visibly. There is no opt-out. -->

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='sd300'>

                    <!--
                      Enabling the license sidecar file in the installer is a four step process:

                      1. Uncomment the `Component` tag and its contents.
                      2. Change the value for the `Source` attribute in the `File` tag to a path
                         to the file that should be included as the license sidecar file. The path
                         can, and probably should be, relative to this file.
                      3. Change the value for the `Name` attribute in the `File` tag to the
                         desired name for the file when it is installed alongside the `bin` folder
                         in the installation directory. This can be omitted if the desired name is
                         the same as the file name.
                      4. Uncomment the `ComponentRef` tag with the Id attribute value of "License"
                         further down in this file.
                    -->
                    <!--
                    <Component Id='License' Guid='*'>
                        <File Id='LicenseFile' Name='ChangeMe' DiskId='1' Source='C:\Path\To\File' KeyPath='yes'/>
                    </Component>
                    -->

                    <!-- Install-source marker (v2.0.0+). sd300 update reads this
                         from HKCU and picks the matching installer to download for
                         in-place upgrades. HKCU even on a perMachine install: the
                         user running this MSI is the user who'll later invoke
                         `sd300 update`. The path-based fallback in
                         Add/Remove Programs recovery in src/update.rs handles
                         a missing marker only when one product/path is
                         unambiguous; it never guesses MSI versus Inno.
                         Value must match the `msi-global` arm in src/update.rs.
                         See wix/corporate.wxs for the perUser sibling. -->
                    <Component Id='InstallSourceMarker' Guid='E66ACB19-F3B7-43DE-B8E6-290A3D966AC3'>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\SD300'
                            Name='InstallSource'
                            Type='string'
                            Value='msi-global'
                            KeyPath='yes'/>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\SD300'
                            Name='InstallSourceGlobal'
                            Type='string'
                            Value='msi-global'/>
                    </Component>
                    <Component Id='NativeInstallRootMarker' Guid='A5881ECD-A207-481B-8D92-2C4FE698C2BB' Win64='yes'>
                        <RegistryValue
                            Root='HKLM'
                            Key='Software\SD300'
                            Name='NativeInstallRootGlobal'
                            Type='string'
                            Value='[APPLICATIONFOLDER]'
                            KeyPath='yes'/>
                    </Component>

                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='D4E8F2A1-6B3C-4D9E-A5F7-1C8B2E0D6A43' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='sd300.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\sd300.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>
                    <Directory Id='Gui' Name='app'>
                        <Component Id='GuiBinaries' Guid='8D74A1E2-6B3F-4FA2-8EB9-20E27B9D9CF1'>
                            <File
                                Id='GuiExe'
                                Name='sd300-gui.exe'
                                DiskId='1'
                                Source='$(var.NativeGuiBinDir)\sd300-gui.exe'
                                KeyPath='yes'/>
                            <File
                                Id='GuiEngine'
                                Name='sd300_engine.dll'
                                DiskId='1'
                                Source='$(var.NativeGuiBinDir)\sd300_engine.dll'/>
                        </Component>
                        <Directory Id='GuiAssets' Name='assets'>
                            <Component Id='GuiIconAsset' Guid='C57A0E7D-43DE-49F6-B390-F22B6BC44A08'>
                                <File
                                    Id='GuiAppIconPng'
                                    Name='app-icon.png'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\assets\app-icon.png'
                                    KeyPath='yes'/>
                                <File
                                    Id='GuiAppIconIco'
                                    Name='app-icon.ico'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\assets\app-icon.ico'/>
                                <File
                                    Id='GuiTrayIconIco'
                                    Name='tray-icon.ico'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\assets\tray-icon.ico'/>
                                <File
                                    Id='GuiTrayIconDarkIco'
                                    Name='tray-icon-dark.ico'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\assets\tray-icon-dark.ico'/>
                                <File
                                    Id='GuiTrayIconLightIco'
                                    Name='tray-icon-light.ico'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\assets\tray-icon-light.ico'/>
                            </Component>
                        </Directory>
                        <Directory Id='GuiLicenses' Name='licenses'>
                            <Component Id='GuiProductLicenseNotice' Guid='C2920BDE-A9CF-4D78-BF05-7854FC657B7E'>
                                <File Id='GuiProductLicense'
                                    Name='PRODUCT-LICENSE.md'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\licenses\PRODUCT-LICENSE.md'
                                    KeyPath='yes'/>
                            </Component>
                            <Component Id='GuiIbmPlexLicenseNotice' Guid='7E8901EC-079F-48CC-A174-6A4D504B9314'>
                                <File Id='GuiIbmPlexLicense'
                                    Name='IBM-PLEX-OFL-1.1.txt'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\licenses\IBM-PLEX-OFL-1.1.txt'
                                    KeyPath='yes'/>
                            </Component>
                            <Component Id='GuiNativeSdkLicenseNotice' Guid='1BC07F1E-DA52-4758-B1C9-8425C29ECD28'>
                                <File Id='GuiNativeSdkLicense'
                                    Name='NATIVE-SDK-APACHE-2.0.txt'
                                    DiskId='1'
                                    Source='$(var.NativeGuiBinDir)\licenses\NATIVE-SDK-APACHE-2.0.txt'
                                    KeyPath='yes'/>
                            </Component>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>
            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ApplicationProgramsFolder' Name='SD-300'>
                    <Component Id='GuiStartMenuShortcut' Guid='DDF6CE8A-0C08-43F4-B546-C47056459B36'>
                        <Shortcut
                            Id='GuiStartMenuShortcutEntry'
                            Name='SD-300'
                            Description='Open the SD-300 native system monitor'
                            Target='[Gui]sd300-gui.exe'
                            WorkingDirectory='Gui'/>
                        <RemoveFolder Id='RemoveApplicationProgramsFolder' On='uninstall'/>
                        <RegistryValue
                            Root='HKCU'
                            Key='Software\SD300'
                            Name='GuiStartMenuShortcutGlobal'
                            Type='integer'
                            Value='1'
                            KeyPath='yes'/>
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs all binaries and the license.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            
            <!--
              Uncomment the following `ComponentRef` tag to add the license
              sidecar file to the installer.
            -->
            <!--<ComponentRef Id='License'/>-->

            <ComponentRef Id='binary0'/>
            <ComponentRef Id='InstallSourceMarker'/>
            <ComponentRef Id='NativeInstallRootMarker'/>
            <ComponentRef Id='GuiBinaries'/>
            <ComponentRef Id='GuiIconAsset'/>
            <ComponentRef Id='GuiProductLicenseNotice'/>
            <ComponentRef Id='GuiIbmPlexLicenseNotice'/>
            <ComponentRef Id='GuiNativeSdkLicenseNotice'/>
            <ComponentRef Id='GuiStartMenuShortcut'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of the [ProductName] executable to the PATH system environment variable. This allows the [ProductName] executable to be called from any location.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
        <!-- A caller may explicitly pass SD300CARGOHOME for a custom Cargo
             installation. Otherwise capture the client environment when MSI
             exposes it, then fall back to the invoking profile's default. -->
        <CustomAction Id='CaptureCargoHome'
            Property='SD300CARGOHOME'
            Value='[%CARGO_HOME]'/>
        <CustomAction Id='DefaultCargoHome'
            Property='SD300CARGOHOME'
            Value='[%USERPROFILE]\.cargo'/>
        <SetProperty Id='StopGuiBeforeMutation'
            Value='&quot;[SD300OWNEDNATIVEROOT]bin\sd300.exe&quot; stop-gui --quiet'
            Sequence='execute'
            Before='StopGuiBeforeMutation'/>

        <!-- Cargo takeover is one Windows Installer transaction. Immediate
             SetProperty rows populate each WixQuietExec action's
             CustomActionData with the exact invoking profile, Cargo home,
             journal, and freshly installed helper path. The rollback action is
             scheduled before the deferred mutation, while the commit action
             marks and removes recovery material only after InstallFinalize.
             Commit return codes are deliberately ignored: once commit cleanup
             begins, a process interruption may leave harmless recovery residue
             but must never initiate a rollback after deleting a backup. -->
        <SetProperty Id='RollbackCargoCopy'
            Value='&quot;[APPLICATIONFOLDER]bin\sd300.exe&quot; mc -s -c -a r -g &quot;[SD300CARGOHOME]&quot; -u &quot;[%USERPROFILE]&quot; -j &quot;[LocalAppDataFolder]SD300\Transactions\msi-g-[ProductCode].json&quot;'
            Sequence='execute'
            Before='RollbackCargoCopy'/>
        <SetProperty Id='CleanCargoCopy'
            Value='&quot;[APPLICATIONFOLDER]bin\sd300.exe&quot; mc -s -c -a p -g &quot;[SD300CARGOHOME]&quot; -u &quot;[%USERPROFILE]&quot; -j &quot;[LocalAppDataFolder]SD300\Transactions\msi-g-[ProductCode].json&quot;'
            Sequence='execute'
            Before='CleanCargoCopy'/>
        <SetProperty Id='CommitCargoCopy'
            Value='&quot;[APPLICATIONFOLDER]bin\sd300.exe&quot; mc -s -c -a c -g &quot;[SD300CARGOHOME]&quot; -u &quot;[%USERPROFILE]&quot; -j &quot;[LocalAppDataFolder]SD300\Transactions\msi-g-[ProductCode].json&quot;'
            Sequence='execute'
            Before='CommitCargoCopy'/>
        <SetProperty Id='InjectPostCargoFailure'
            Value='&quot;[SystemFolder]cmd.exe&quot; /d /c exit /b 1'
            Sequence='execute'
            Before='InjectPostCargoFailure'/>
        <CustomAction Id='RollbackCargoCopy'
            BinaryKey='WixCA'
            DllEntry='WixQuietExec64'
            Execute='rollback'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='CleanCargoCopy'
            BinaryKey='WixCA'
            DllEntry='WixQuietExec64'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='CommitCargoCopy'
            BinaryKey='WixCA'
            DllEntry='WixQuietExec64'
            Execute='commit'
            Impersonate='yes'
            Return='ignore'/>
        <CustomAction Id='InjectPostCargoFailure'
            BinaryKey='WixCA'
            DllEntry='WixQuietExec64'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <!-- An explicit MSI install is the user's newest channel choice. Remove
             the same-edition Inno product before MSI writes shared-path files,
             preventing duplicate ARP registrations and a stale uninstaller.
             Type 34 requires a full executable path, so use the exact Inno
             AppId registration's UninstallString rather than assuming a
             relative unins000.exe resolves from the application directory. -->
        <CustomAction Id='RemoveConflictingInno'
            Directory='TARGETDIR'
            ExeCommand='[CONFLICTING_INNO_UNINSTALL] /VERYSILENT /SUPPRESSMSGBOXES /NORESTART /PRESERVEGUISTATE'
            Execute='deferred'
            Impersonate='no'
            Return='check'/>
        <CustomAction Id='CleanOtherEdition'
            FileKey='exe0'
            ExeCommand='migrate-cleanup --quiet --strict --other-edition'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='StopGuiBeforeMutation'
            BinaryKey='WixCA'
            DllEntry='WixQuietExec64'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='VerifyGuiCompanion'
            Directory='TARGETDIR'
            ExeCommand='&quot;[Gui]sd300-gui.exe&quot; --self-test --json'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>
        <CustomAction Id='CleanupGuiState'
            FileKey='exe0'
            ExeCommand='cleanup-gui-state --quiet'
            Execute='deferred'
            Impersonate='yes'
            Return='check'/>

        <InstallExecuteSequence>
            <Custom Action='CaptureCargoHome' Before='SetRollbackCargoCopy'>
                <![CDATA[NOT Installed AND NOT SD300CARGOHOME]]>
            </Custom>
            <Custom Action='DefaultCargoHome' After='CaptureCargoHome'>
                <![CDATA[NOT Installed AND NOT SD300CARGOHOME]]>
            </Custom>
            <Custom Action='StopGuiBeforeMutation' Before='RemoveExistingProducts'>
                <![CDATA[SD300OWNEDNATIVEROOT AND NOT SD300GUIALREADYSTOPPED]]>
            </Custom>
            <Custom Action='RemoveConflictingInno' Before='InstallFiles'>
                <![CDATA[CONFLICTING_INNO_UNINSTALL AND NOT REMOVE~="ALL"]]>
            </Custom>
            <!-- Qualify the newly installed companion before any cleanup that
                 mutates pre-existing Cargo or other-edition ownership. If the
                 self-test fails, MSI rollback can remove only this package and
                 leave the user's prior command untouched. -->
            <Custom Action='VerifyGuiCompanion' After='InstallFiles'>
                <![CDATA[NOT REMOVE~="ALL"]]>
            </Custom>
            <Custom Action='CleanOtherEdition' After='VerifyGuiCompanion'>
                <![CDATA[NOT Installed]]>
            </Custom>
            <Custom Action='RollbackCargoCopy' After='CleanOtherEdition'>
                <![CDATA[NOT Installed]]>
            </Custom>
            <Custom Action='CleanCargoCopy' After='RollbackCargoCopy'>
                <![CDATA[NOT Installed]]>
            </Custom>
            <Custom Action='InjectPostCargoFailure' After='CleanCargoCopy'>
                <![CDATA[NOT Installed AND SD300TESTFAILAFTERCARGO = "1"]]>
            </Custom>
            <Custom Action='CommitCargoCopy' After='InjectPostCargoFailure'>
                <![CDATA[NOT Installed]]>
            </Custom>
            <Custom Action='CleanupGuiState' Before='RemoveFiles'>
                <![CDATA[REMOVE~="ALL" AND NOT UPGRADINGPRODUCTCODE AND NOT SD300PRESERVEGUISTATE]]>
            </Custom>
        </InstallExecuteSequence>


        <Icon Id='ProductICO' SourceFile='wix\Product.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />

        <Property Id='ARPHELPLINK' Value='https://github.com/QubeTX/qube-system-diagnostics'/>
        
        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            
            <!--
              Enabling the EULA dialog in the installer is a three step process:

                1. Comment out or remove the two `Publish` tags that follow the
                   `WixVariable` tag.
                2. Uncomment the `<WixVariable Id='WixUILicenseRtf' Value='Path\to\Eula.rft'>` tag further down
                3. Replace the `Value` attribute of the `WixVariable` tag with
                   the path to a RTF file that will be used as the EULA and
                   displayed in the license agreement dialog.
            -->
        </UI>

        
        <!--
          Enabling the EULA dialog in the installer requires uncommenting
          the following `WixUILicenseRTF` tag and changing the `Value`
          attribute.
        -->
        <!-- <WixVariable Id='WixUILicenseRtf' Value='Relative\Path\to\Eula.rtf'/> -->

        
        <!--
          Uncomment the next `WixVariable` tag to customize the installer's
          Graphical User Interface (GUI) and add a custom banner image across
          the top of each screen. See the WiX Toolset documentation for details
          about customization.

          The banner BMP dimensions are 493 x 58 pixels.
        -->
        <!--<WixVariable Id='WixUIBannerBmp' Value='wix\Banner.bmp'/>-->

        
        <!--
          Uncomment the next `WixVariable` tag to customize the installer's
          Graphical User Interface (GUI) and add a custom image to the first
          dialog, or screen. See the WiX Toolset documentation for details about
          customization.

          The dialog BMP dimensions are 493 x 312 pixels.
        -->
        <!--<WixVariable Id='WixUIDialogBmp' Value='wix\Dialog.bmp'/>-->

    </Product>

</Wix>
